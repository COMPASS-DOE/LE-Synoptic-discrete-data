str_replace_all(c(
"[Ww][tT]"     = "W",
"[Tt][Rr][a]?" = "TR",
"[Uu][Pp]"     = "UP",
"[Ww][lL]"     = "W"
)) %>%
str_replace("(\\d+)_?([A-Za-z])$", "\\1\\L\\2")%>%
str_c(Site, ., sep = "_")
)
unique(alldat$label)
