# QAQC flags
fluxes_flagged <- fluxes %>%
mutate(
# model fit flags
CO2_lin_pass  = (lin_r.squared  >= 0.85 | lin_RMSE  < 5) & !is.na(lin_r.squared),
CO2_HM81_pass = (HM81_r.squared >= 0.85 | HM81_RMSE < 5) & !is.na(HM81_r.squared),
CO2_poly_pass = (poly_r.squared >= 0.85 | poly_RMSE < 5) & !is.na(poly_r.squared),
# negative flux flag
CO2_neg_flux       = lin_flux.estimate < 0 | is.na(lin_flux.estimate),
# rejection flags
CO2_rejected_model  = !(CO2_lin_pass | CO2_HM81_pass | CO2_poly_pass),
CO2_rejected_negflux = CO2_neg_flux,
CO2_flux_rejected   = CO2_rejected_model | CO2_rejected_negflux
)
# percentage of problems
r2_summary <- fluxes_flagged %>%
summarise(
CO2_total_obs          = n(),
CO2_n_rejected_model   = sum(CO2_rejected_model,   na.rm = TRUE),
CO2_n_rejected_negflux = sum(CO2_rejected_negflux, na.rm = TRUE),
CO2_n_rejected_both    = sum(CO2_rejected_model & CO2_rejected_negflux, na.rm = TRUE),
CO2_n_rejected_total   = sum(CO2_flux_rejected,    na.rm = TRUE),
CO2_pct_rejected_total = 100 * CO2_n_rejected_total / CO2_total_obs,
CO2_n_lin_pass         = sum(CO2_lin_pass,  na.rm = TRUE),
CO2_n_HM81_pass        = sum(CO2_HM81_pass, na.rm = TRUE),
CO2_n_poly_pass        = sum(CO2_poly_pass, na.rm = TRUE)
)
# formatted table for PDF
r2_summary %>%
tidyr::pivot_longer(everything(), names_to = "Metric", values_to = "Value") %>%
mutate(
Metric = recode(Metric,
CO2_total_obs          = "Total observations",
CO2_n_rejected_model   = "Rejected вЂ” poor model fit (n)",
CO2_n_rejected_negflux = "Rejected вЂ” negative CO2 flux (n)",
CO2_n_rejected_both    = "Rejected вЂ” both reasons (n)",
CO2_n_rejected_total   = "Rejected вЂ” total (n)",
CO2_pct_rejected_total = "Rejected вЂ” total (%)",
CO2_n_lin_pass         = "Passed вЂ” Linear model (n)",
CO2_n_HM81_pass        = "Passed вЂ” HM81 model (n)",
CO2_n_poly_pass        = "Passed вЂ” Polynomial model (n)"
),
Value = ifelse(Metric == "Rejected вЂ” total (%)",
round(Value, 1),
as.integer(Value)) ) %>%
kable(
caption  = "QA/QC CO2 Flux Summary",
align    = c("l", "r"),
booktabs = TRUE,
format   = "latex") %>%
kable_styling(
latex_options = c("striped", "hold_position"),
full_width    = FALSE ) %>%
pack_rows("Rejections",        2, 6) %>%
pack_rows("Model performance", 7, 9)
# RВІ vs RMSE diagnostic plot
# pivot_longer keeps RВІ/RMSE columns and uses CO2_*_pass as the pass indicator
set.seed(42)
plot_data <- fluxes_flagged %>%
slice_sample(n = min(15000, nrow(.))) %>%
select(
lin_r.squared,  lin_RMSE,  CO2_lin_pass,
HM81_r.squared, HM81_RMSE, CO2_HM81_pass,
poly_r.squared, poly_RMSE, CO2_poly_pass,
CO2_rejected_negflux
) %>%
# rename pass columns to match model prefix before pivoting
rename(
lin_pass  = CO2_lin_pass,
HM81_pass = CO2_HM81_pass,
poly_pass = CO2_poly_pass
) %>%
pivot_longer(
cols = -CO2_rejected_negflux,
names_to  = c("model", ".value"),
names_pattern = "(lin|HM81|poly)_(.*)"
) %>%
rename(r2 = r.squared) %>%
mutate(
model  = recode(model, lin = "Linear", HM81 = "HM81", poly = "Polynomial"),
status = case_when(
CO2_rejected_negflux ~ "Negative CO2",
pass                 ~ "Accepted",
TRUE                 ~ "Rejected"
)
) %>%
filter(!is.na(r2), !is.na(RMSE))
#graphing
QAQC_plot <- ggplot(plot_data, aes(x = r2, y = RMSE, color = model, shape = status)) +
geom_point(size = 2) +
geom_vline(xintercept = 0.85, linetype = "dashed", color = "black", linewidth = 0.8) +
geom_hline(yintercept = 5,    linetype = "dashed", color = "black", linewidth = 0.8) +
annotate("text", x = 0.7, y = max(plot_data$RMSE, na.rm = TRUE) * 0.95,
label = "RВІ = 0.85", hjust = -0.1, size = 3.5, fontface = "bold") +
annotate("text", x = 0.1, y = 5,
label = "RMSE = 5", vjust = -0.5, size = 3.5, fontface = "bold") +
scale_color_manual(values = c(
"Linear"     = "#E41A1C",
"HM81"       = "#377EB8",
"Polynomial" = "#4DAF4A"
)) +
scale_shape_manual(values = c(
"Accepted"     = 16,
"Rejected"     = 4,
"Negative CO2" = 17 )) +
labs(
title = "RВІ vs RMSE вЂ” CO2 Flux QA/QC",
x     = "RВІ",
y     = "RMSE",
color = "Model",
shape = "Status"  ) +
theme_bw(base_size = 13) +
theme(legend.position = "right")
print(QAQC_plot)
print(QAQC_plot)
fluxes_flagged$CO2_neg_flux
sum(fluxes_flagged$CO2_neg_flux)
