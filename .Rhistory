t_end_trim   = max(TIMESTAMP) )
unique(alldat_trimmed$Plot)
unique(time_overrides$Plot)
alldat_trimmed %>%
filter(Plot == "7/13/2023_CRC_TR_315_115") %>%
ggplot(aes(TIMESTAMP, CO2)) +
geom_point() + theme_classic()
