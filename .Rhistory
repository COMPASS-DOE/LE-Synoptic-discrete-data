# ---- função CORRETA para extrair data do SmartChamber ----
extract_date <- function(file) {
# ler como JSON (txt/dat também são JSON)
x <- tryCatch(fromJSON(file, simplifyVector = TRUE), error = function(e) NULL)
if (is.null(x)) return(NA)
# navegar pela estrutura
reps <- x[[1]]$reps
if (is.null(reps)) return(NA)
dates <- sapply(reps, function(r) {
# prioridade 1: header$Date
if (!is.null(r$header$Date)) {
return(as.Date(ymd_hms(r$header$Date)))
}
# fallback: header$gps_time
if (!is.null(r$header$gps_time)) {
return(as.Date(as.POSIXct(
as.numeric(r$header$gps_time),
origin = "1970-01-01", tz = "UTC"
)))
}
NA
})
unique(na.omit(dates))
}
# aplicar a todos os arquivos
all_dates <- unique(unlist(lapply(file_paths, extract_date)))
