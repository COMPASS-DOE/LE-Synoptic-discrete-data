# --- caminho do ZIP ---
zip_file <- "D:/GitHub/LE-Synoptic-discrete-data/Soil_Fluxes_Synoptic_LE/2024/Raw Data_LE_2024.zip"
stopifnot(file.exists(zip_file))
# --- diretório temporário ---
tmp_dir <- tempdir()
# --- listar e extrair arquivos ---
zip_contents <- unzip(zip_file, list = TRUE)
data_files <- zip_contents$Name[
grepl("\\.(json|txt|dat)$", zip_contents$Name, ignore.case = TRUE)
]
unzip(zip_file, files = data_files, exdir = tmp_dir)
file_paths <- file.path(tmp_dir, data_files)
# --- função para extrair timestamps de UM arquivo ---
extract_dates <- function(file) {
ext <- tolower(tools::file_ext(file))
df <- tryCatch({
if (ext == "json") {
as.data.frame(fromJSON(file, flatten = TRUE))
} else {
fread(file, showProgress = FALSE)
}
}, error = function(e) return(NULL))
if (is.null(df)) return(NULL)
# possíveis colunas de tempo
time_cols <- intersect(
names(df),
c("TIMESTAMP", "timestamp", "gps_time", "time", "datetime", "date_time")
)
if (length(time_cols) == 0) return(NULL)
# tentar converter todas as colunas possíveis
dates <- lapply(time_cols, function(col) {
x <- df[[col]]
if (is.numeric(x)) {
as.Date(as.POSIXct(x, origin = "1970-01-01", tz = "UTC"))
} else {
suppressWarnings(as.Date(ymd_hms(x, tz = "UTC")))
}
})
unique(na.omit(unlist(dates)))
}
# --- aplicar a todos os arquivos ---
all_dates <- unique(unlist(lapply(file_paths, extract_dates)))
# --- resultado final ---
all_dates <- sort(all_dates)
print(all_dates)
