"[Tt][Rr][a]?" = "TR",
"[Uu][Pp]"     = "UP",
"[Ww][lL]"     = "W",
"[w]"          = "W"
)) %>%
## ✅ ÚNICA normalização correta do sufixo
str_replace("(\\d+)_?([A-Za-z])$", "\\1\\L\\2") %>%
## site (já está OK)
str_replace(
.,
"^",
if_else(
is.na(Site) | str_detect(., paste0("^", Site, "_?")),
"",
paste0(Site, "_")
)
)
)
