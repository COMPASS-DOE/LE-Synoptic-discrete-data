# Create a temporary directory
tmp_dir <- tempdir()
# Path to ZIP (use absolute to be safe)
zip_file <- "D:/GitHub/LE-Synoptic-discrete-data/Soil_Fluxes_Synoptic_LE/2024/Raw Data_LE_2024.zip"
if (!file.exists(zip_file)) {
stop("ZIP file not found: ", zip_file)
}
# Inspect ZIP
zip_contents <- unzip(zip_file, list = TRUE)
# Select SmartChamber raw files
raw_files <- zip_contents$Name[
grepl("\\.(json|txt|data)$", zip_contents$Name, ignore.case = TRUE) &
!grepl("manifest|test|generic", zip_contents$Name, ignore.case = TRUE)
]
# Extract to tempdir
unzip(zip_file, files = raw_files, exdir = tmp_dir)
# List extracted files
file.list <- list.files(
path = tmp_dir,
pattern = "\\.(json|txt|data)$",
full.names = TRUE,
recursive = TRUE
)
# ---- FIX: rename JSON saved as .txt --------------------------
txt_files <- file.list[grepl("\\.txt$", file.list, ignore.case = TRUE)]
for (f in txt_files) {
first_line <- readLines(f, n = 1, warn = FALSE)
if (grepl("^\\s*\\{", first_line)) {
file.rename(f, sub("\\.txt$", ".json", f, ignore.case = TRUE))
}
}
# FINAL file list: JSON ONLY
file.list <- list.files(
path = tmp_dir,
pattern = "\\.json$",
full.names = TRUE,
recursive = TRUE
)
# Read SmartChamber data
alldat1 <- lapply(file.list, function(f) {
tryCatch(
ffi_read_LIsmartchamber(f),
error = function(e) NULL
)
})
# Keep only valid reads
alldat1 <- alldat1[sapply(alldat1, function(x) !is.null(x) && nrow(x) > 0)]
# Combine
alldat <- data.table::rbindlist(alldat1, fill = TRUE)
# alldat  - date formatting
alldat <- alldat %>%
mutate(Date = as.Date(TIMESTAMP))%>%filter(lubridate::year(Date) == 2024)
unique(alldat$Date)
# Create a temporary directory
tmp_dir <- tempdir()
# Path to the zip file
zip_file <- "D:/GitHub/LE-Synoptic-discrete-data/Soil_Fluxes_Synoptic_LE/2024/Raw Data_LE_2024.zip"
if (!file.exists(zip_file)) {stop("ZIP file not found: ", zip_file)}
# List files inside the zip
zip_contents <- unzip(zip_file, list = TRUE)
# Select SmartChamber files (json, txt, data)
raw_files <- zip_contents$Name[ grepl("\\.(json|txt|data)$", zip_contents$Name, ignore.case = TRUE) &
!grepl("manifest|test|generic", zip_contents$Name, ignore.case = TRUE)]
if (length(raw_files) == 0) {stop("No SmartChamber files found inside ZIP.")}
# Extract selected files
unzip(zip_file,
files = raw_files,
exdir = tmp_dir)
# List extracted files (REAL paths on disk)
file.list <- list.files(
path = tmp_dir,
pattern = "\\.(json|txt|data)$",
full.names = TRUE,
recursive = TRUE)
# Read ALL SmartChamber files (json, txt, data)
alldat1 <- lapply(file.list, function(f) {
tryCatch(
ffi_read_LIsmartchamber(f),
error = function(e) {
message("Skipped file: ", basename(f))
NULL} )})
# Keep only successful reads with data
alldat1 <- alldat1[
sapply(alldat1, function(x) !is.null(x) && nrow(x) > 0)]
# Combine into a single table
alldat <- data.table::rbindlist(alldat1, fill = TRUE)
