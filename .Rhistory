``
# ------------------------------------------------------------
# Visual QA/QC of incubation period adjustments
# (USE alldat_matched, NOT alldat_trimmed)
# ------------------------------------------------------------
r_all <- alldat_matched %>%
filter(Plot %in% time_overrides$Plot) %>%
left_join(time_overrides, by = "Plot") %>%
group_by(Plot) %>%
mutate(
# limites originais
t_start_original = min(TIMESTAMP),
t_end_original   = max(TIMESTAMP),
# limites ajustados (deadband + stop time)
t_start_adjusted = if_else(
!is.na(dead_band_manual),
t_start_original + dead_band_manual,
t_start_original + as.numeric(coalesce(first(Dead_band), 0))
),
t_end_adjusted = if_else(
!is.na(stop_offset_secs),
t_end_original + stop_offset_secs,
t_end_original
),
# classificaГ§ГЈo visual
point_status = case_when(
TIMESTAMP < t_start_adjusted ~ "Discarded (deadband)",
TIMESTAMP > t_end_adjusted   ~ "Discarded (stop trim)",
TRUE                         ~ "Used"
)
) %>%
ungroup()
# ------------------------------------------------------------
# Plot (Quarto-safe)
# ------------------------------------------------------------
if (nrow(r_all) == 0) {
warning("Nenhum dado vГЎlido para plotar Incubation Period Adjustments.")
} else {
ggplot(r_all, aes(x = TIMESTAMP, y = CO2, color = point_status)) +
geom_point(size = 1.8) +
facet_wrap(~ Plot, scales = "free", ncol = 2) +
scale_color_manual(
values = c(
"Used"                  = "#E41A1C",  # vermelho
"Discarded (deadband)"  = "grey60",
"Discarded (stop trim)" = "grey20"
)
) +
theme_classic() +
ylab(expression(paste(CO[2], " (ppm)"))) +
xlab("Time") +
labs(
title = "Incubation Period Adjustments",
color = "Point Status"
) +
theme(legend.position = "bottom")
}
# checar se os nomes batem
time_overrides$Plot
unique(alldat_matched$Plot)[1:10]
# quantos matches existem?
sum(alldat_matched$Plot %in% time_overrides$Plot)
# grab trim limits for each overridden Plot
trim_limits <- alldat_trimmed %>%
filter(Plot %in% time_overrides$Plot) %>%
group_by(Plot) %>%
summarise(
t_start_trim = min(TIMESTAMP),
t_end_trim   = max(TIMESTAMP),
.groups = "drop"
)
# diagnostic: check for mismatches
n_matched <- sum(alldat_matched$Plot %in% time_overrides$Plot)
message("Plots in time_overrides found in alldat_matched: ", n_matched)
if (n_matched == 0) {
message("No matching plots found. Checking name formats:")
message("time_overrides plots: ")
print(time_overrides$Plot)
message("Sample of alldat_matched plots: ")
print(head(unique(alldat_matched$Plot), 20))
stop("Fix plot name mismatch before proceeding.")
}
# after you match the data for the first time - we can just read the .rds file to save processing time here
# if you need to match licor data and metadata again, remove "#" from the previous chunks
alldat_matched <- readRDS("alldat_matched_2023b.rds")
## Extract initial CO2 concentration (t0) for each Plot for QAQC later
#saving df to use after flux calculation
df_CO2_in <- alldat_matched %>%
arrange(Plot, TIMESTAMP) %>%
group_by(Plot) %>%
summarise(CO2_initial = first(CO2), .groups = "drop")
# reading temp
temps <- read.csv("Raw Data/L2_temp_timeseries.csv")
# make sure timestamps are in the correct format
# convert to tibble early to avoid data.table list-column issues
alldat_matched <- as_tibble(alldat_matched) %>%
mutate(across(where(is.list), ~ as.numeric(unlist(.))))
alldat_matched$TIMESTAMP <- as.POSIXct(alldat_matched$TIMESTAMP, format = "%Y-%m-%d %H:%M:%OS")
alldat_matched$Dead_band <- as.numeric(alldat_matched$Dead_band)
# fix midnight timestamps in L2 data
temps$TIMESTAMP[!grepl(":", temps$TIMESTAMP)] <-
paste0(temps$TIMESTAMP[!grepl(":", temps$TIMESTAMP)], " 00:00:00")
temps$TIMESTAMP <- as.POSIXct(temps$TIMESTAMP, format = "%Y-%m-%d %H:%M:%OS")
# time rounding
alldat_matched$TIMESTAMP_round <- round_date(alldat_matched$TIMESTAMP, "60 mins")
temps$TIMESTAMP_round           <- round_date(temps$TIMESTAMP, "60 mins")
# one observation per hour
temps_clean <- temps %>%
group_by(TIMESTAMP_round, Site) %>%
summarize(Temp = mean(Temp), .groups = "drop")
# join weather station temp
alldat_matched <- alldat_matched %>%
left_join(temps_clean, by = c("Site", "TIMESTAMP_round"))
# в”Ђв”Ђ DIAGNOSTIC: which plots are missing Temp after join в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
temp_missing_check <- alldat_matched %>%
group_by(Plot, Site) %>%
summarise(
n_obs       = n(),
n_temp_na   = sum(is.na(Temp)),
pct_temp_na = round(100 * n_temp_na / n_obs, 1),
month       = month(first(TIMESTAMP)),
.groups     = "drop"
) %>%
filter(n_temp_na > 0)
message("Plots with missing Temp: ", nrow(temp_missing_check))
print(temp_missing_check)
# в”Ђв”Ђ IMPUTATION: monthly mean per site as fallback в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
monthly_temp <- alldat_matched %>%
mutate(month = month(TIMESTAMP)) %>%
filter(!is.na(Temp)) %>%
group_by(Site, month) %>%
summarise(Temp_monthly_mean = mean(Temp), .groups = "drop")
alldat_matched <- alldat_matched %>%
mutate(
month      = month(TIMESTAMP),
Temp       = as.numeric(Temp)
) %>%
left_join(monthly_temp, by = c("Site", "month")) %>%
mutate(
Temp_source = case_when(
!is.na(Temp)              ~ "weather_station",
!is.na(Temp_monthly_mean) ~ "monthly_mean_imputed",
TRUE                      ~ "still_missing"
),
Temp = coalesce(Temp, Temp_monthly_mean)
) %>%
select(-Temp_monthly_mean, -month)
# в”Ђв”Ђ FINAL CHECK в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
message("Temp source summary:")
alldat_matched$Temp_source <- as.character(alldat_matched$Temp_source)
table(alldat_matched$Temp_source)
still_missing <- alldat_matched %>%
filter(Temp_source == "still_missing") %>%
distinct(Plot, Site)
if (nrow(still_missing) > 0) {
message("WARNING: ", nrow(still_missing), " plots still have no Temp after imputation:")
print(still_missing)
} else {
message("All plots have Temp after imputation.")
}
#change the units
alldat_trimmed$CO2_umol <- ffi_ppm_to_umol(alldat_trimmed$CO2,
volume = alldat_trimmed$Volume, # m3
temp = alldat_trimmed$Temp)    # degrees C from the weather station
#> Assuming atm = 101325 Pa
#> Using R = 8.31446261815324 m3 Pa K-1 mol-1
alldat_trimmed$CO2_umol_m2 <- alldat_trimmed$CO2_umol / 0.16
fluxes <- ffi_compute_fluxes(alldat_trimmed ,
group_column = "Plot",
time_column = "TIMESTAMP",
gas_column = "CO2_umol_m2",
dead_band = 0)
head(fluxes)
#merging fluxes with initial CO2 concentration
fluxes <- fluxes %>%
left_join(df_CO2_in,by = "Plot")
#take a look at the fluxes we calculated with R2
ggplot(fluxes, aes(Plot, lin_flux.estimate, color = lin_r.squared)) +
geom_point(size=4) + theme_classic() +
geom_linerange(aes(ymin = lin_flux.estimate- lin_flux.std.error,
ymax = lin_flux.estimate+ lin_flux.std.error)) +
scale_color_gradientn(colours = c("darkred",  "red", "white","lightblue", "darkblue"),
values = c(0, 0.5, 0.6, 0.7, 1)) +
ylab("CO2 flux (umol/m2/s)")
#sort fluxes by R2
fluxes_good <- as.data.frame(subset(fluxes, lin_r.squared >= .90, select = Plot:TIMESTAMP_max))
fluxes_lowr2 <- as.data.frame(subset(fluxes, lin_r.squared < .90 & lin_flux.estimate < 1, select = Plot:TIMESTAMP_max))
fluxes_weird <- as.data.frame(subset(fluxes, lin_r.squared < .90, select = Plot:TIMESTAMP_max))
#find fluxes that represent the first and fourth quartile of the data
low <- quantile(fluxes$lin_flux.estimate, 0.05)
high <- quantile(fluxes$lin_flux.estimate, 0.95)
fluxes_low <- as.data.frame(subset(fluxes, lin_flux.estimate <= low, select = Plot:TIMESTAMP_max))
fluxes_high <- as.data.frame(subset(fluxes, lin_flux.estimate >= high, select = Plot:TIMESTAMP_max))
tails <- rbind(fluxes_low, fluxes_high)
# grab trim limits for each overridden Plot
trim_limits <- alldat_trimmed %>%
filter(Plot %in% time_overrides$Plot) %>%
group_by(Plot) %>%
summarise(
t_start_trim = min(TIMESTAMP),
t_end_trim   = max(TIMESTAMP) )
# use full alldat_matched + trim limits to classify each point
r_all <- alldat_matched %>%
filter(Plot %in% time_overrides$Plot) %>%
left_join(trim_limits, by = "Plot") %>%
group_by(Plot) %>%
mutate(
time_sec = as.numeric(difftime(TIMESTAMP, min(TIMESTAMP), units = "secs")),
point_status = case_when(
TIMESTAMP < t_start_trim ~ "Discarded (deadband)",
TIMESTAMP > t_end_trim   ~ "Discarded (stop trim)",
TRUE                     ~ "Used"  )) %>%
ungroup()
# plot all overridden plots
ggplot(r_all, aes(x = TIMESTAMP, y = CO2, color = point_status)) +
geom_point(size = 1.8) +
facet_wrap(~ Plot, scales = "free", ncol = 2) +
scale_color_manual(
values = c(
"Used"                  = "#E41A1C",
"Discarded (deadband)"  = "grey60",
"Discarded (stop trim)" = "grey20"
)
) +
theme_classic() +
ylab(expression(paste(CO[2], " (ppm)"))) +
xlab("Time") +
labs(
title = "Incubation Period Adjustments",
color = "Point Status") +
theme(legend.position = "bottom")
