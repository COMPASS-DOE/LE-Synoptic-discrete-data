"2023_01_05_OWC_TR_60_1",
"2023_07_13_CRC_TR_33_2",
"2023_06_22_OWC_TR_68_2",
"2023_06_22_OWC_W_69_2",
"2023_07_13_CRC_TR_37_2",
"2023_06_22_OWC_UP_55_2",
"2023_06_22_OWC_TR_64_2",
"2023_04_21_OWC_UP_58_2",
"2023_07_13_CRC_TR_34_3_2",
"2023_06_22_OWC_UP_52_1",
"2023_06_22_OWC_TR_60_2",
"2023_05_10_OWC_TR_61_1",
"2023_06_22_OWC_TR_58_1",
"2023_06_22_OWC_W_67_2",
"2023_06_29_CRC_TR_36_2",
"2023_05_10_OWC_TR_63_2",
"2023_01_05_OWC_TR_63_1"
),
DeadBand_override = c(
