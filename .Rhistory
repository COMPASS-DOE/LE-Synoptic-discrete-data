# Some SmartChamber JSON files are saved with .txt extension.
# Fluxfinder chooses parser by extension, so these must be renamed.
txt_files <- file.list[grepl("\\.txt$", file.list, ignore.case = TRUE)]
for (f in txt_files) {
first_line <- readLines(f, n = 1, warn = FALSE)
if (grepl("^\\s*\\{", first_line)) {
file.rename(
f,
sub("\\.txt$", ".json", f, ignore.case = TRUE)
)
}
}
