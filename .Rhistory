)
}
}
do.call(rbind, out)
}
res <- do.call(rbind, lapply(file.list, check_file))
res
bad <- subset(res, ch4_n == 0 | co2_n == 0 | ch4_n != co2_n)
library(jsonlite)
check_file <- function(f) {
dat <- fromJSON(f, simplifyVector = FALSE)
# segurança absoluta
if (is.null(dat$datasets) || length(dat$datasets) == 0) {
return(data.frame(
file = basename(f),
dataset = NA,
rep = NA,
ch4_n = NA,
co2_n = NA
))
}
out <- list()
for (d in seq_along(dat$datasets)) {
reps <- dat$datasets[[d]]$reps
if (is.null(reps) || length(reps) == 0) next
for (r in names(reps)) {
ch4_n <- length(reps[[r]]$data$ch4 %||% list())
co2_n <- length(reps[[r]]$data$co2 %||% list())
out[[length(out) + 1]] <- data.frame(
file = basename(f),
dataset = d,
rep = r,
ch4_n = ch4_n,
co2_n = co2_n
)
}
}
# garante retorno sempre como data.frame
if (length(out) == 0) {
return(data.frame(
file = basename(f),
dataset = NA,
rep = NA,
ch4_n = NA,
co2_n = NA
))
}
do.call(rbind, out)
}
bad <- subset(
res,
is.na(ch4_n) | is.na(co2_n) | ch4_n == 0 | co2_n == 0 | ch4_n != co2_n
)
