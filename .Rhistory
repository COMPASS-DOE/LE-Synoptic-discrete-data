library(fluxfinder)
library(ggplot2)
library(ggpubr)
library(lubridate)
library(dplyr)
library(tidyr)
library(tidyverse)
library(stringr)
# Create a temporary directory
tmp_dir <- tempdir()
# Get list of files inside the zip
zip_contents <- unzip("Raw Data_LE_2023.zip", list = TRUE)
# Keep only JSON files
json_files <- zip_contents$Name[grepl("json$", zip_contents$Name, ignore.case = TRUE)]
# Extract only the JSON files
unzip(
"Raw Data_LE_2023.zip",
files = json_files,
exdir = tmp_dir
)
# List extracted JSON files (full paths)
file.list <- list.files(
path = tmp_dir,
pattern = "json$",
full.names = TRUE,
recursive = TRUE
)
head(file.list)
# Read in the data
alldat1 <- lapply(file.list, ffi_read_LIsmartchamber)
res <- lapply(file.list, function(f) {
cat("Reading:", basename(f), "\n")
tryCatch(
ffi_read_LIsmartchamber(f),
error = function(e) {
message("FAILED: ", basename(f))
return(NULL)
}
)
})
good <- res[[which(!sapply(res, is.null))[1]]]
str(good)
jsonlite::fromJSON(file.list[which(sapply(res, is.null))[1]], simplifyVector = FALSE)
# Create a temporary directory
tmp_dir <- tempdir()
# Get list of files inside the zip
zip_contents <- unzip("Raw Data_LE_2023.zip", list = TRUE)
# Keep only JSON files
json_files <- zip_contents$Name[grepl("json$", zip_contents$Name, ignore.case = TRUE)]
# Extract only the JSON files
unzip(
"Raw Data_LE_2023.zip",
files = json_files,
exdir = tmp_dir
)
# List extracted JSON files (full paths)
file.list <- list.files(
path = tmp_dir,
pattern = "json$",
full.names = TRUE,
recursive = TRUE
)
head(file.list)
# Read in the data
alldat1 <- lapply(file.list, ffi_read_LIsmartchamber)
library(jsonlite)
check_file <- function(f) {
dat <- fromJSON(f, simplifyVector = FALSE)
# tenta navegar até os dados, sem quebrar se algo não existir
ch4_len <- tryCatch(
length(unlist(dat$datasets[[1]]$CRC_UP_29$reps[[1]]$data$ch4)),
error = function(e) NA
)
co2_len <- tryCatch(
length(unlist(dat$datasets[[1]]$CRC_UP_29$reps[[1]]$data$co2)),
error = function(e) NA
)
data.frame(
file = basename(f),
ch4_n = ch4_len,
co2_n = co2_len
)
}
do.call(rbind, lapply(file.list, check_file))
library(jsonlite)
check_file_full <- function(f) {
dat <- fromJSON(f, simplifyVector = FALSE)
out <- list()
for (d in seq_along(dat$datasets)) {
reps <- dat$datasets[[d]]$reps
for (r in names(reps)) {
ch4_n <- length(reps[[r]]$data$ch4)
co2_n <- length(reps[[r]]$data$co2)
out[[length(out) + 1]] <- data.frame(
file = basename(f),
dataset = d,
rep = r,
ch4_n = ch4_n,
co2_n = co2_n
)
}
}
do.call(rbind, out)
}
res <- do.call(rbind, lapply(file.list, check_file_full))
res
bad <- subset(
res,
is.na(ch4_n) | is.na(co2_n) | ch4_n == 0 | co2_n == 0 | ch4_n != co2_n
)
