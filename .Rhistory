library(fluxfinder)
library(data.table)
library(dplyr)
library(lubridate)
# -------------------------------
# 1) Caminho do ZIP e temp dir
# -------------------------------
zip_file <- "D:/GitHub/LE-Synoptic-discrete-data/Soil_Fluxes_Synoptic_LE/2024/Raw Data_LE_2024.zip"
stopifnot(file.exists(zip_file))
tmp_dir <- tempdir()
# -------------------------------
# 2) Extrair arquivos do ZIP
# -------------------------------
zip_contents <- unzip(zip_file, list = TRUE)
raw_files <- zip_contents$Name[
grepl("\\.(json|txt|dat)$", zip_contents$Name, ignore.case = TRUE)
]
unzip(zip_file, files = raw_files, exdir = tmp_dir)
file_paths <- file.path(tmp_dir, raw_files)
# -------------------------------
# 3) Renomear JSON disfarçado (.txt / .dat -> .json)
# -------------------------------
for (f in file_paths) {
first_line <- tryCatch(readLines(f, n = 1, warn = FALSE), error = function(e) "")
if (grepl("^\\s*\\{", first_line)) {
new_name <- sub("\\.(txt|dat)$", ".json", f, ignore.case = TRUE)
if (new_name != f) file.rename(f, new_name)
}
}
# -------------------------------
# 4) Ler TODOS os SmartChamber com ffi
# -------------------------------
json_files <- list.files(tmp_dir, pattern = "\\.json$", full.names = TRUE, recursive = TRUE)
alldat_list <- lapply(json_files, function(f) {
tryCatch(
ffi_read_LIsmartchamber(f),
error = function(e) NULL
)
})
# manter só leituras válidas
alldat_list <- alldat_list[
sapply(alldat_list, function(x) !is.null(x) && nrow(x) > 0)
]
# bind final
alldat <- data.table::rbindlist(alldat_list, fill = TRUE)
# -------------------------------
# 5) RECONSTRUIR timestamp corretamente
# -------------------------------
alldat <- alldat %>%
mutate(
TIMESTAMP_FIXED = case_when(
# JSON mais novos
!is.na(TIMESTAMP) ~ as.POSIXct(TIMESTAMP, tz = "UTC"),
