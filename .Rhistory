library(jsonlite)
library(lubridate)
extract_date <- function(file) {
x <- tryCatch(fromJSON(file, simplifyVector = FALSE),
error = function(e) return(NA))
# x precisa ser lista
if (!is.list(x) || length(x) == 0) return(NA)
root <- x[[1]]
# estrutura esperada
if (!is.list(root) || is.null(root$reps)) return(NA)
reps <- root$reps
dates <- sapply(reps, function(r) {
if (!is.list(r) || is.null(r$header)) return(NA)
# prioridade 1: header$Date (string)
if (!is.null(r$header$Date)) {
d <- suppressWarnings(ymd_hms(r$header$Date))
if (!is.na(d)) return(as.Date(d))
}
# fallback: gps_time (epoch)
if (!is.null(r$header$gps_time)) {
return(as.Date(as.POSIXct(
as.numeric(r$header$gps_time),
origin = "1970-01-01",
tz = "UTC"
)))
}
NA
})
unique(na.omit(dates))
}
# aplicar a todos os arquivos
all_dates <- unique(unlist(lapply(file_paths, extract_date)))
# resultado final
all_dates <- sort(all_dates)
print(all_dates)
all_dates <- as.Date(all_dates, origin = "1970-01-01")
print(all_dates)
