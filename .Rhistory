TIMESTAMP_FIXED = case_when(
# caso normal
!is.na(TIMESTAMP) ~ as.POSIXct(TIMESTAMP, tz = "UTC"),
# fallback: gps_time (epoch seconds)
is.na(TIMESTAMP) & !is.na(gps_time) ~
as.POSIXct(gps_time, origin = "1970-01-01", tz = "UTC"),
# fallback: timestamp (epoch seconds)
is.na(TIMESTAMP) & !is.na(timestamp) ~
as.POSIXct(timestamp, origin = "1970-01-01", tz = "UTC"),
TRUE ~ NA_POSIXct_
),
Date = as.Date(TIMESTAMP_FIXED)
)
