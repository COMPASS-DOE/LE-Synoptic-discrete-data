full.names = TRUE,
recursive = TRUE
)
# ---- FIX LI-COR EXPORT ISSUE ----------------------------------
# Some SmartChamber JSON files are saved with .txt extension.
# Fluxfinder chooses parser by extension, so these must be renamed.
txt_files <- file.list[grepl("\\.txt$", file.list, ignore.case = TRUE)]
for (f in txt_files) {
first_line <- readLines(f, n = 1, warn = FALSE)
if (grepl("^\\s*\\{", first_line)) {
file.rename(
f,
sub("\\.txt$", ".json", f, ignore.case = TRUE)
)
}
}
# Refresh file list after renaming
file.list <- list.files(
path = tmp_dir,
pattern = "\\.json$",
full.names = TRUE,
recursive = TRUE
)
# Read SmartChamber files
alldat1 <- lapply(file.list, function(f) {
tryCatch(
ffi_read_LIsmartchamber(f),
error = function(e) NULL
)
})
# Keep only successful reads with data
alldat1 <- alldat1[
sapply(alldat1, function(x) !is.null(x) && nrow(x) > 0)
]
# Combine into one data.table
alldat <- data.table::rbindlist(alldat1, fill = TRUE)
