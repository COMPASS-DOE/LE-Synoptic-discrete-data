alldat_matched <- match_flux_metadata(alldat, metadat)
message("Matched dataset rows: ", nrow(alldat_matched))
head(alldat_matched)
#saving matched data and metadata as raw data is too big (today, Licor files leave in the COMPASS drive)
saveRDS(alldat_matched, file = "alldat_matched_2023.rds")
#can remove any row that have NA's in the CO2 column
#alldat <- alldat %>%
