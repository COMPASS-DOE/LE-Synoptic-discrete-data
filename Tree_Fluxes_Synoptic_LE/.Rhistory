n_total <- nrow(fluxes_all)
r2_summary <- fluxes_all %>%
mutate(
lin_bad   = lin_r.squared < 0.9 | is.na(lin_r.squared),
hm81_bad  = HM81_r.squared < 0.9 | is.na(HM81_r.squared),
poly_bad  = poly_r.squared < 0.9 | is.na(poly_r.squared),
fail_all_models = lin_bad & hm81_bad & poly_bad,
pass_at_least_one = !(fail_all_models),
neg_CO2 = lin_flux.estimate < 0 | is.na(lin_flux.estimate)
) %>%
summarise(
total_obs = n(),
n_lin_r2_below_0.9 = sum(lin_bad, na.rm = TRUE),
pct_lin_r2_below_0.9 = 100 * n_lin_r2_below_0.9 / total_obs,
n_fail_all_models = sum(fail_all_models, na.rm = TRUE),
pct_fail_all_models = 100 * n_fail_all_models / total_obs,
n_pass_at_least_one = sum(pass_at_least_one, na.rm = TRUE),
pct_pass_at_least_one = 100 * n_pass_at_least_one / total_obs,
n_neg_CO2 = sum(neg_CO2, na.rm = TRUE),
pct_neg_CO2 = 100 * n_neg_CO2 / total_obs
)
r2_summary
