## Match metadata to raw data

```{r}

#match the metadata to the concentration data 
# matching SN
match_flux_metadata <- function(alldat, metadat) {

  # Identify instruments strictly from metadata
  instruments <- intersect(
    unique(metadat$SN),
    unique(alldat$SN)
  )

  results <- lapply(instruments, function(sn) {

    message("Processing SN: ", sn)

    # Subset data and metadata for this instrument
    dat_i <- alldat %>% 
      filter(SN == sn)

    meta_i <- metadat %>% 
      filter(SN == sn) %>%
      arrange(Date, Time_start)

    # Create explicit metadata index
    meta_i$metadat_row <- seq_len(nrow(meta_i))

    # Temporal matching
    dat_i$metadat_row <- fluxfinder::ffi_metadata_match(
      data_timestamps = dat_i$TIMESTAMP,
      start_dates     = meta_i$Date,
      start_times     = meta_i$Time_start,
      obs_lengths     = meta_i$Obs_length
    )

    # Attach metadata INSIDE the SN loop (this is the part you were missing)
    dat_i$Plot      <- meta_i$Plot[dat_i$metadat_row]
    dat_i$Volume    <- meta_i$Volume[dat_i$metadat_row]
    dat_i$Temp      <- meta_i$Temp[dat_i$metadat_row]
    dat_i$Site      <- meta_i$Site[dat_i$metadat_row]
    dat_i$Dead_band <- meta_i$Dead_band[dat_i$metadat_row]

    # Drop unmatched timestamps
    dat_i <- dat_i %>% 
      filter(!is.na(metadat_row))

    return(dat_i)
  })

  alldat_final <- match_flux_metadata(alldat, metadat)
  
  # Combine all instruments back
  alldat_final <- data.table::rbindlist(results, fill = TRUE)

  return(alldat_final)
}

# creating te final df
alldat_final <- match_flux_metadata(alldat, metadat)

#can remove any row that have NA's in the CH4 column 
#alldat <- alldat %>%
 # filter(!is.na(CH4))

```

