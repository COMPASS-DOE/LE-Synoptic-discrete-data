knitr::opts_chunk$set(echo = TRUE)
#install.packages("remotes") # if necessary
#remotes::install_github("COMPASS-DOE/fluxfinder")
library(fluxfinder)
library(ggplot2)
library(ggpubr)
library(lubridate)
library(dplyr)
library(tidyr)
library(tidyverse)
library(stringr)
allflux_filtered_renamed <- allflux_filtered %>%
separate(
Plot_ID,
into = c("Year", "Month_num", "Day", "Site", "Zone", "Rest"),
sep = "_",
fill = "right",
extra = "merge",
remove = FALSE
) %>%
mutate(
Month = month.abb[as.integer(Month_num)],
# RepNumber is always the final number
RepNumber = as.integer(str_extract(Plot_ID, "[0-9]+$")),
# Replicate = numeric collar ID only (removes letters like a, b)
Replicate = as.integer(str_extract(Rest, "^[0-9]+"))
) %>%
rename(Plot = Plot_ID) %>%
select(
RepNumber, Month, Site, Zone, Replicate, Plot,
everything(),
-Year, -Day, -Month_num, -Rest, -base_id
)
# Create a temporary directory
tmp_dir <- tempdir()
# Get list of files inside the zip
zip_contents <- unzip("Raw Data_LE_2023.zip", list = TRUE)
# Keep only JSON files
json_files <- zip_contents$Name[grepl("json$", zip_contents$Name, ignore.case = TRUE)]
# Extract only the JSON files
unzip(
"Raw Data_LE_2023.zip",
files = json_files,
exdir = tmp_dir
)
# List extracted JSON files (full paths)
file.list <- list.files(
path = tmp_dir,
pattern = "json$",
full.names = TRUE,
recursive = TRUE
)
head(file.list)
# Read in the data
alldat1 <- lapply(file.list, ffi_read_LIsmartchamber)
# Combine into one data.table
alldat <- data.table::rbindlist(alldat1, fill = TRUE)
## Noticed that the site names were recorded in the file name and not in the flux label for 2023
## dealing with it in the next chunk
# Table describing the days we have visited each site
site_lookup <- tibble::tribble(
~Date,         ~Site,
"2023-01-20",  "CRC",
"2023-02-21",  "CRC",
"2023-03-24",  "CRC",
"2023-04-14",  "CRC",
"2023-05-30",  "CRC",
"2023-06-29",  "CRC",
"2023-07-13",  "CRC",
"2023-08-03",  "CRC",
"2023-09-01",  "CRC",
"2023-10-06",  "CRC",
"2023-01-05",  "OWC",
"2023-02-10",  "OWC",
"2023-03-28",  "OWC",
"2023-04-21",  "OWC",
"2023-05-10",  "OWC",
"2023-06-22",  "OWC",
"2023-07-25",  "OWC",
"2023-08-10",  "OWC",
"2023-09-08",  "OWC",
"2023-10-20",  "OWC",
"2023-01-12",  "PTR",
"2023-02-24",  "PTR",
"2023-07-26",  "PTR",
"2023-08-17",  "PTR",
"2023-10-11",  "PTR"
) %>%
mutate(Date = as.Date(Date))
# alldat  - date formatting
alldat <- alldat %>%
mutate(Date = as.Date(TIMESTAMP))%>%
left_join(site_lookup, by = "Date")
# Fixing label code problems
alldat <- alldat %>%
## Remove known invalid labels
filter(!label %in% c("Test2", "Up30", "Up30c", "Up27")) %>%
## Normalize the raw label (do NOT trust embedded site)
mutate(
label = label %>%
str_remove_all("[sSeE]") %>%          # remove stray s/e
str_replace_all("-", "_") %>%         # standardize separators
str_replace_all(c(
"[Ww][tT]"     = "W",
"[Tt][Rr][a]?" = "TR",
"[Uu][Pp]"     = "UP",
"[Ww][lL]"     = "W",
"[w]"          = "W"
)) %>%
## ensure ZONE_NUMBER format (W46 → W_46, TR34 → TR_34)
str_replace("_(W|TR|UP)(\\d)", "_\\1_\\2") %>%
## separate suffix from number (48a → 48_a)
str_replace("(\\d+)([A-Za-z])$", "\\1_\\2")
) %>%
## Remove ANY site embedded in the original label
mutate(
label_core = str_remove(label, "^(CRC|OWC|PTR)_?")
) %>%
## Rebuild label using ONLY the site from site_lookup  #OWC recorded wrongly on 2023-Jan-12 instead of PTR
mutate(
label = paste0(Site, "_", label_core)
) %>%
## Standardize suffixes (only when they exist)
mutate(
n_underscores = str_count(label, "_"),
suffix = str_extract(label, "(?<=_)[^_]+$"),
label = if_else(
n_underscores >= 3 & !is.na(suffix),
str_replace(
label,
paste0("_", suffix, "$"),
paste0("_", tolower(suffix))
),
label
)
) %>%
## Final cleanup
select(-label_core, -n_underscores, -suffix)
#I have to change labels that were recorded wrong - tracked in the field notes
# CRC 02-21-2023 TR 36 -> recorded as W but it is a TR sample
# CRC 02-21-2023 TR 37 -> recorded as W but it is a TR sample
# CRC 02-21-2023 TR 38 -> recorded as UP but it is a TR sample
# CRC 02-21-2023 TR 40 -> recorded as UP but it is a TR sample
# CRC 03-24-2023 W 48 -> recorded as TR but it is a W sample
# CRC 10-06-2023 TR 37 -> recorded as UP but it is a TR sample
# CRC 10-06-2023 TR 39 -> recorded as UP but it is a TR sample
# CRC 10-06-2023 TR 40 -> recorded as UP but it is a TR sample
# OWC 04-21-2023 TR 58 -> recorded as UP but it is a TR sample
# OWC 04-21-2023 TR 60 -> recorded as UP but it is a TR sample
# OWC 04-21-2023 TR 61 -> recorded as UP but it is a TR sample
# OWC 04-21-2023 TR 63 -> recorded as UP but it is a TR sample
# OWC 04-21-2023 TR 64 -> recorded as UP but it is a TR sample
#extracting the collar number from the label
alldat <- alldat %>%
mutate(
PlotNum = as.integer(stringr::str_extract(label, "(?<=_)\\d+(?=(_|$))"))
)
#correcting the zone that was saved wrongly
alldat <- alldat %>%
mutate( label = case_when(
# CRC 02-21-2023 — TR was saved wrongly as W
Site == "CRC" & Date == as.Date("2023-02-21") & PlotNum %in% c(36, 37) ~
stringr::str_replace(label, "_W_", "_TR_"),
Site == "CRC" & Date == as.Date("2023-02-21") & PlotNum %in% c(38, 40) ~
stringr::str_replace(label, "_UP_", "_TR_"),
# CRC 03-24-2023 — W was saved wrongly as TR
Site == "CRC" & Date == as.Date("2023-03-24") & PlotNum == 48 ~
stringr::str_replace(label, "_TR_", "_W_"),
# CRC 10-06-2023 — TR was saved wrongly as UP
Site == "CRC" & Date == as.Date("2023-10-06") & PlotNum %in% c(37, 39, 40) ~
stringr::str_replace(label, "_UP_", "_TR_"),
# OWC 04-21-2023 — UP was saved wrongly as TR
Site == "OWC" & Date == as.Date("2023-04-21") & PlotNum %in% c(58, 60, 61, 63, 64) ~
stringr::str_replace(label, "_UP_", "_TR_"),
TRUE ~ label
)
)
############### only run this first part if you don't already have a meta-data file
#because if you do then all the data for each one will have a plot and you won't be able to change start times
#create unique Plot ID for each measurement:
#detach("package:data.table", unload=TRUE)
# I am changing this from a month_ID to a date_ID as I have more than one day per month
alldat <- alldat %>%
mutate(
Date_str = format(as.Date(TIMESTAMP), "%Y_%m_%d"),
Plot_ID = str_c(Date_str, label, RepNum, sep = "_")  )
#this needs to be PLot ID so that later we ID plot from metadata and not the metadata row
# Path inside the zip
zip_file <- "Raw Data_LE_2023.zip"
csv_inside_zip <- "Raw Data/COMPASS_SmartChamber_Metadata_2023.csv"
# Make sure the destination folder exists
dir.create("Raw Data", showWarnings = FALSE)
# Extract only the metadata CSV if it doesn't already exist
if (!file.exists(csv_inside_zip)) {
unzip(
zip_file,
files = csv_inside_zip,
exdir = "."
)
}
# Define the file path where you want to save the CSV file
file_path <- "Raw Data/COMPASS_SmartChamber_Metadata_2023.csv"
# Check if the CSV file exists
if (file.exists(file_path)) {
# If it exists, read it back into R
metadata <- read.csv(file_path)
print("CSV file exists and has been read into the code.")
} else {
# If it does not exist, create the CSV file
#create a metadata file from the Plot IDs
# pull timestart timestamps to put in the metadata and obs lengths
metadata <- alldat %>%
group_by(InstrumentSerialNumber, Plot_ID) %>%
summarise(SN = first(InstrumentSerialNumber), #Roberta => I included this to process more than one licor per time
Date = format(min(TIMESTAMP), "%Y-%m-%d"),
Time_start = format(min(TIMESTAMP), "%H:%M:%S"),
First_Timestamp = min(TIMESTAMP),  # Minimum (earliest) timestamp for each Plot_ID
Last_Timestamp = max(TIMESTAMP),   # Maximum (latest) timestamp for each Plot_ID
Total_Time = as.numeric(difftime(max(TIMESTAMP), min(TIMESTAMP), units = "secs")),  # Time difference in seconds
) %>%
ungroup() %>%
mutate(Total_Time = pmin(Total_Time, 60),
drop = FALSE,# Add a 'drop' column with 'FALSE' for every row
Notes = "")
#mutate(notes = " ")  # Add a 'drop' column with 'FALSE' for every row
#mutate(Deadband = 5)
#mutate(Plot = Plot_ID) #think need this because we need to make a plot column
# Write df_unique to CSV
write.csv(metadata, file = file_path, row.names = FALSE)
print("CSV file does not exist. It has been created.")
}
# fluxes that were retaken have similar names with a letter after it
metadata_filtered <- metadata %>%
mutate(
# Base plot ID (everything before the last _number or _number_letter)
base_id = str_replace(Plot_ID, "_[0-9]+(_[a-z])?$", ""),
# Replicate number (e.g., 32 from 1_Jul_CRC_UP_32 or 1_Jul_CRC_UP_32_b)
replicate = as.numeric(
str_extract(Plot_ID, "(?<=_)[0-9]+(?=(_[a-z])?$)")
),
# Suffix letter (if present); otherwise empty string
letter = str_extract(base_id, "(?<=_)[A-Za-z]$"),
letter = if_else(is.na(letter), "", letter),
# Letter order to define order: "" < a < b < c < d ...
letter_order = if_else(
letter == "",
0L,
match(letter, letters)  ) )
#creating a core ID to compare the retaken obs
metadata_filtered <- metadata_filtered %>%
mutate(
# ID for plot not considering retake (remove _a, _b, _c, etc.)
core_id = str_remove(base_id, "_[A-Za-z]$")
) %>%
group_by(core_id) %>%
mutate(
drop = letter_order < max(letter_order, na.rm = TRUE)
) %>%
ungroup()
#remove any metadata rows that have NAs for the PlotID
metadata_filtered  <- metadata_filtered %>%
filter(!is.na(Plot_ID)) %>%
filter(str_detect(Plot_ID, paste(c("OWC", "CRC", "PTR"), collapse = "|")))
alldat<-alldat%>% filter(!is.na(label))
#match the altered metadata to the concentration data with fluxfinder ffi_metadata_match
# this next part was adapted to include SN and process all Licors at the same time, handling overlapping timestamp among >1 licor instruments.
# matching SN
alldat <- alldat %>%
rename(SN=InstrumentSerialNumber)%>%
group_by(SN) %>%
mutate(
metadat_row = ffi_metadata_match(
data_timestamps = TIMESTAMP,
start_dates     = metadata_filtered$Date[metadata_filtered$SN == first(SN)],
start_times     = metadata_filtered$Time_start[metadata_filtered$SN == first(SN)],
obs_lengths     = metadata_filtered$Total_Time[metadata_filtered$SN == first(SN)]
)
) %>%
ungroup()
alldat <- alldat %>%
left_join(
metadata_filtered %>% mutate(metadat_row = row_number()),
by = c("SN", "metadat_row", "Plot_ID")
)
#problems with labels - there was a chamber Offset of 75 instead of 5 and chamber volume of 0 from the smart chamber
alldat <- alldat %>%
mutate(
# Fix the Offset bug Plot_ID OWC_02-10-2023 W 67: 75 -> 5 and recalculating volume based on different Offsets
Offset_cm = if_else(Offset == 75, 5, Offset),
# Fix chamber bug: volume should never be zero
ChamVolume_fixed_cm3 = if_else(
ChamVolume == 0,
4244.1,
ChamVolume
),
# Recalculate collar volume (cm3)
CollarVolume_cm3 = Area * Offset_cm,
# Recalculate total volume (cm3)
TotalVolume_fixed_cm3 =
ChamVolume_fixed_cm3 +
IrgaVolume +
CollarVolume_cm3,
)
# Table of plots with custom deadband adjustments
deadband_overrides <- tibble::tibble(
Plot_ID = c(
"2023_06_29_CRC_UP_29_1",
"2023_05_10_OWC_TR_61_1",
"2023_06_22_OWC_TR_60_2",
"2023_06_22_OWC_TR_63_2",
"2023_06_29_CRC_UP_26_2",
"2023_06_22_OWC_TR_65_2",
"2023_07_13_CRC_TR_39_2",
"2023_01_05_OWC_TR_60_1",
"2023_07_13_CRC_TR_33_2",
"2023_06_22_OWC_TR_68_2",
"2023_06_22_OWC_W_69_2",
"2023_07_13_CRC_TR_37_2",
"2023_06_22_OWC_UP_55_2",
"2023_06_22_OWC_TR_64_2",
"2023_04_21_OWC_UP_58_2",
"2023_07_13_CRC_TR_34_3_2",
"2023_06_22_OWC_UP_52_1",
"2023_06_22_OWC_TR_60_2",
"2023_05_10_OWC_TR_61_1",
"2023_06_22_OWC_TR_58_1",
"2023_06_22_OWC_W_67_2",
"2023_06_29_CRC_TR_36_2",
"2023_05_10_OWC_TR_63_2",
"2023_01_05_OWC_TR_63_1"
),
DeadBand_override = c(
5,
7,
6,
10,
8,
12,
9,
11,
13,
7,
10,
11,
9,
9,
10,
9,
8,
11,
14,
8,
11,
11,
16,
12
)
)
# Default deadband
alldat <- alldat %>%
mutate(DeadBand_used = DeadBand)
# Apply per-plot overrides
alldat <- alldat %>%
left_join(deadband_overrides, by = "Plot_ID") %>%
mutate(
DeadBand_used = if_else(
!is.na(DeadBand_override),
DeadBand_override,
DeadBand_used
)
) %>%
select(-DeadBand_override)
#change the units
alldat$CH4_nmol <- ffi_ppb_to_nmol(alldat$ch4,
volume = (alldat$TotalVolume_fixed_cm3 / 1000000), # have to divide to get to m3
temp = alldat$chamber_t)    # degrees C
#> Assuming atm = 101325 Pa
#> Using R = 8.31446261815324 m3 Pa K-1 mol-1
alldat$CH4_nmol_m2 <- alldat$CH4_nmol / 0.0318 #adjust for the area
#need to create a new line that would say only calculate the flux if the drop column is false
alldat_dropped<-alldat%>%filter(drop!=TRUE)
#selecting the base id to include in the flux df later
plot_base_lookup <- alldat %>%
select(Plot_ID, base_id)%>%
filter(!is.na(base_id)) %>%
distinct(Plot_ID, .keep_all = TRUE)
#calculate fluxes for all other sites
fluxes <- ffi_compute_fluxes(alldat_dropped,
group_column = "Plot_ID",
time_column = "TIMESTAMP",
gas_column = "CH4_nmol_m2",
dead_band = "DeadBand_used")
head(fluxes)
#including the unique ID
fluxes <- fluxes %>%
left_join(plot_base_lookup, by = "Plot_ID")
##Create a dataframe with averaged soil probe data per Plot and add to flux data
soildat <- alldat %>%
group_by(Plot_ID) %>%
dplyr::summarize(
soilp_c = mean(soilp_c, na.rm=TRUE),
soilp_m = mean(soilp_m, na.rm=TRUE),
soilp_t = mean(soilp_t, na.rm=TRUE))
alldf <- left_join(fluxes, soildat, by = "Plot_ID")
#reading the list of negative CO2 flux
drop_neg_CO2 <- readRDS("drop_neg_CO2_2023.rds")%>%
dplyr::select(Plot_ID,drop_CO2)
alldf <- alldf %>%
left_join(drop_neg_CO2, by = "Plot_ID")%>%
mutate(drop_CO2 = coalesce(drop_CO2, FALSE))
allflux <-alldf%>%filter(drop_CO2!=TRUE)
# Create a new dataframe by removing rows that were present in fluxes_weird (11 obs)
#allflux_filtered <- allflux[!(allflux$Plot_ID %in% fluxes_weird$Plot_ID), ] # not all of them are bad, so I am removing below the ones we visually confirmed that were bad
#Any others that are not in the weird category that need to be removed:
#also removing ones that are crazy off but were not in the fluxes_weird dataframe
allflux_filtered <- allflux %>%
filter(!Plot_ID %in% c("2022_07_07_PTR_TR_9_1", #chamber closing issue
"2022_07_08_CRC_W_44_1",    #bumps
"2022_07_08_CRC_TR_36_1", #chamber closing issue
"2022_10_05_OWC_W_68_1"   #chamber closing issue
))
# TO DO..
# reduce the stop time for 202_07_20_CRC_W_43_1 to 52sec; for 202_07_08_CRC_W_44_2 to 46sec
# View the result
head(allflux_filtered)
allflux_filtered_renamed <- allflux_filtered %>%
separate(
Plot_ID,
into = c("Year", "Month_num", "Day", "Site", "Zone", "Rest"),
sep = "_",
fill = "right",
extra = "merge",
remove = FALSE
) %>%
mutate(
Month = month.abb[as.integer(Month_num)],
# RepNumber is always the final number
RepNumber = as.integer(str_extract(Plot_ID, "[0-9]+$")),
# Replicate = numeric collar ID only (removes letters like a, b)
Replicate = as.integer(str_extract(Rest, "^[0-9]+"))
) %>%
rename(Plot = Plot_ID) %>%
select(
RepNumber, Month, Site, Zone, Replicate, Plot,
everything(),
-Year, -Day, -Month_num, -Rest, -base_id
)
#export as a csv to the folder that you want
write.csv(allflux_filtered_renamed, file="Processed Data/COMPASS_Synoptic_LE_SmartChamber_Fluxes_Final_2023_CH4.csv", row.names = FALSE)
setwd("D:/GitHub/LE-Synoptic-discrete-data/Soil_FluxesSynoptic_LE/2023")
#export as a csv to the folder that you want
